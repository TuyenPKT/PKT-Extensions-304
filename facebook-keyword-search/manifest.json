{
  "manifest_version": 3,
  "name": "PKT Facebook Keyword Search",
  "version": "1.0.0",
  "description": "Tự động tìm kiếm từ khóa trên Facebook từ file text",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["https://www.facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PKT Facebook Search"
  },
  "background": {
    "service_worker": "background.js"
  }
}
